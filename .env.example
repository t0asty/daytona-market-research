# =============================================================================
# Environment template — copy to `.env` and fill in values (`.env` is gitignored).
# Load before running CLI:  set -a && source .env && set +a
# Sanity-check (prints set/missing only, never secret values):  marketing-orchestrator doctor
# This repo does not auto-load `.env`; you must export or source it yourself.
# =============================================================================

# -----------------------------------------------------------------------------
# Daytona (SDK: orchestrator run-remote, SEO sandbox runner, snapshot scripts)
# Get your key from the Daytona dashboard / your org settings.
# -----------------------------------------------------------------------------
DAYTONA_API_KEY=""

# Optional — defaults match daytona-sdk if omitted:
# DAYTONA_API_URL="https://app.daytona.io/api"
# DAYTONA_TARGET="eu"

# Snapshot used when creating sandboxes (must exist in your Daytona account).
# Marketing orchestrator tries MARKETING_SNAPSHOT_NAME, then SEO_SNAPSHOT_NAME, then seo-agent-v1.
# SEO_SNAPSHOT_NAME="seo-agent-v1"
# MARKETING_SNAPSHOT_NAME="seo-agent-v1"

# Optional sandbox lifecycle (minutes) for marketing remote runs:
# MARKETING_SANDBOX_AUTO_STOP_MIN="20"
# MARKETING_SANDBOX_AUTO_ARCHIVE_MIN="60"
# MARKETING_SANDBOX_AUTO_DELETE_MIN="120"

# -----------------------------------------------------------------------------
# OpenAI — local only (e.g. report-gen --llm). Do not put this inside sandboxes
# if your provider blocks datacenter IPs; polish reports on your machine instead.
# -----------------------------------------------------------------------------
OPENAI_API_KEY="sk-paste-your-openai-key-here"
# OPENAI_MODEL="gpt-4o-mini"

# -----------------------------------------------------------------------------
# SEO Daytona demo / web UI defaults (when using report_gen web + Daytona)
# -----------------------------------------------------------------------------
# SEO_DEFAULT_DOMAIN="example.com"
# SEO_DEFAULT_KEYWORDS="keyword one, keyword two"
# SEO_DEFAULT_COMPETITORS="competitor.com, other.com"
# SEO_LOCALE="en-US"
# SEO_MAX_KEYWORDS="50"
# SEO_MAX_PAGES="20"
