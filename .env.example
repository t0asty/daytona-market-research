# Optional: only needed when running report-gen --llm
OPENAI_API_KEY=

# ── Daytona sandbox execution (optional) ─────────────────
# When set, "Run analyst agents" spawns real Daytona sandboxes
# instead of simulating with fixture files.
# Get your API key at https://app.daytona.io/dashboard/keys
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_TARGET=us
SEO_SNAPSHOT_NAME=seo-agent-v1

# ── SEO research configuration ───────────────────────────
# Target domain and seed keywords for Daytona-powered runs
SEO_DEFAULT_DOMAIN=example.com
SEO_DEFAULT_KEYWORDS=seo,marketing,digital strategy
SEO_DEFAULT_COMPETITORS=
SEO_LOCALE=en-US
SEO_MAX_KEYWORDS=50
SEO_MAX_PAGES=20
